    @* Твій JS-скрипт прев'ю картинки + Скрипт автоматичного відкриття вікна при помилці *@
    <script>

        // Логіка перевідкриття модального вікна, якщо сервер повернув помилку
        @if (TempData["OpenModal"] != null)
        {
            <text>
                document.addEventListener("DOMContentLoaded", function () {
                var modalId = "@TempData["OpenModal"]" === "login" ? "modularAuthorizationWindow" : "modularRegistrationWindow";
                var modalElement = document.getElementById(modalId);
                if (modalElement) {
                var myModal = new bootstrap.Modal(modalElement);
                myModal.show();
                }
                });
            </text>
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>