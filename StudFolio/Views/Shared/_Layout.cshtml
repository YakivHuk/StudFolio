                                <a class="dark-nav-link" asp-area="" asp-controller="Posts" asp-action="Index">Пости</a>
                            </li>
                            <li>
                                <a class="dark-nav-link" asp-area="" asp-controller="Portfolio" asp-action="Index">Портфоліо</a>
                            </li>
                            <li>
                                @if (User.Identity.IsAuthenticated)
                                {
                                    <a class="dark-nav-link" asp-area="" asp-controller="MyPortfolio" asp-action="Index">Моє портфоліо</a>
                                }
                                else
                                {
                                    <a class="dark-nav-link" role="button" data-bs-toggle="modal" data-bs-target="#modularAuthorizationWindow">Моє портфоліо</a>
                                }
