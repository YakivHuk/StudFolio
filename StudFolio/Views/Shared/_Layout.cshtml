                                {
                                    <a class="dark-nav-link" asp-area="" asp-controller="Settings" asp-action="Index">Налаштування</a>
                                }
                                else
                                {
                                    <a class="dark-nav-link" role="button" data-bs-toggle="modal" data-bs-target="#modularAuthorizationWindow">Налаштування</a>
                                }
                            </li>
                            <li>
                                @if (User.Identity.IsAuthenticated)
                                {
                                    <a class="dark-nav-link" asp-area="" asp-controller="MyPortfolio" asp-action="Index">Моє портфоліо</a>
                                }
                                else
                                {
