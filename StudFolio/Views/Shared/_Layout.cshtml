                                @if (User.Identity.IsAuthenticated)
                                {
                                    <a class="dark-nav-link" asp-area="" asp-controller="MyPosts" asp-action="Index">Мої пости</a>
                                }
                                else
                                {
                                    <a class="dark-nav-link" role="button" data-bs-toggle="modal" data-bs-target="#modularAuthorizationWindow">Мої пости</a>
                                }
                            </li>
                            <li>
                                @if (User.Identity.IsAuthenticated)
                                {
                                    <a class="dark-nav-link" asp-area="" asp-controller="Settings" asp-action="Index">Налаштування</a>
                                }
                                else
                                {
                                    <a class="dark-nav-link" role="button" data-bs-toggle="modal" data-bs-target="#modularAuthorizationWindow">Налаштування</a>
                                }
                            </li>
                        </ul>
                    </div>
                    <div class="col">
                        <p class="h5 mb-4">Підтримка</p>
                        <ul class="nav flex-column gap-2">
                            <li>
                                <a class="dark-nav-link" asp-area="" asp-controller="Home" asp-action="Index" asp-fragment="frequently-asked-questions">Часті питання</a>
                            </li>
                            <li>
                                <a class="dark-nav-link" href="mailto:support@studfolio.if.ua">Написати е-листа</a>
                            </li>
                        </ul>
                    </div>
                    <div class="col">
                        <p class="h5 mb-4">Керування</p>
                        <ul class="nav flex-column gap-2">
